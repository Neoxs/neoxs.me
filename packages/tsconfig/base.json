{
    "$schema": "https://json.schemastore.org/tsconfig",
    "compilerOptions": {
      "strict": true,
      "skipLibCheck": true,
      "noUnusedLocals": true,
      "noUnusedParameters": true,
      "moduleResolution": "bundler",
      "resolveJsonModule": true,
      "isolatedModules": true,
      "esModuleInterop": true
    }
  }