{
  "name": "neoxs.me",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "build:shell": "turbo run build --filter=shell",
    "build:blog": "turbo run build --filter=mfe-blog",
    "build:lab": "turbo run build --filter=mfe-lab",
    "build:infra": "turbo run build --filter=mfe-infra",
    "dev": "turbo run dev",
    "dev:shell": "turbo run dev --filter=shell",
    "dev:blog": "turbo run dev --filter=mfe-blog",
    "dev:lab": "turbo run dev --filter=mfe-lab",
    "dev:infra": "turbo run dev --filter=mfe-infra",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "check-types": "turbo run check-types",
    "secretlint": "secretlint \"apps/**/*\" \"packages/**/*\" \"infra/**/*\" \".github/**/*\" \"docker/**/*\" \"*.md\"",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,tsx,md,vue,mjs,cjs,yml,yaml,json}": "secretlint",
    "**/Dockerfile": "secretlint"
  },
  "devDependencies": {
    "@secretlint/secretlint-rule-preset-recommend": "^13.0.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.7.4",
    "secretlint": "^13.0.0",
    "turbo": "^2.9.6",
    "typescript": "^5"
  },
  "packageManager": "pnpm@10.33.2",
  "engines": {
    "node": ">=22",
    "pnpm": ">=10"
  }
}
